body {
    margin: 0;
    font-family: "Proxima Nova", Arial, sans-serif;
    background-color: #FED8C1;
    color: #003366;
}


/* Top Bar */
.top-bar {
    background-color: #708090;
    color: white;
    text-align: center;
    padding: 12px;
    font-size: 16px;
}


/* Navigation */
nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 60px;
}


.logo img {
    width: 150px;
}


.nav-links {
    display: flex;
    align-items: center;
    gap: 25px;
}


.nav-links a {
    text-decoration: none;
    color: #003366;
    font-weight: bold;
}


/* Buttons */
button {
    border: none;
    cursor: pointer;
    font-weight: bold;
}


.contact {
    background-color: yellow;
    color: #003366;
    padding: 12px 25px;
    border-radius: 25px;
}


.donate {
    padding: 16px 35px;
    border-radius: 30px;
    color: white;

    background: linear-gradient(
        90deg,
        yellow,
        #708090,
        #003366
    );
}


/* Hero Section */
.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 70px 60px;
}


.hero-text {
    width: 50%;
}


h1 {
    font-size: 55px;
}


p {
    font-size: 20px;
    line-height: 1.6;
}


.hero-image {
    width: 40%;
}


.hero-image img {
    width: 100%;
    border-radius: 20px;
}
